---
import BaseLayout from '../../layouts/BaseLayout.astro';
import cases from '../../data/cases.json';

export function getStaticPaths() {
  return cases.map((c) => ({ params: { id: c.id }, props: { caseItem: c } }));
}
const { caseItem } = Astro.props;
---
<BaseLayout title={`${caseItem.name} - 整装案例设计 - 无碍e家`} showBreadcrumb breadcrumb={[{ label: '首页', href: '/' }, { label: '整装案例设计', href: '/cases' }, { label: caseItem.name }]}>
  <article class="animate-spring-fade">
    <div class="flex items-center gap-3 mb-6">
      <span class="px-3 py-1 rounded-xl text-xs glass-strong text-morandi-muted">{caseItem.category}</span>
      <h1 class="text-2xl sm:text-3xl font-semibold text-morandi-text tracking-tight">{caseItem.name}</h1>
    </div>

    <section class="glass rounded-2xl p-6 sm:p-8 mb-8">
      <h2 class="text-lg font-semibold text-morandi-text mb-3">设计介绍</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">{caseItem.description}</p>
    </section>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {caseItem.images.map((img: string, i: number) => (
        <div class="glass rounded-2xl overflow-hidden animate-spring-in" style={`animation-delay: ${Math.min(i * 0.05, 0.3)}s`}>
          <img src={img} alt={`${caseItem.name} - 图${i + 1}`} class="w-full h-56 object-cover" loading="lazy" />
        </div>
      ))}
    </div>

    <div class="mt-8">
      <a href="/cases" class="inline-flex items-center gap-2 text-sm text-morandi-muted hover:text-morandi-text spring-btn transition-colors duration-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        返回整装案例设计
      </a>
    </div>
  </article>
</BaseLayout>
