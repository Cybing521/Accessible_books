---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookList from '../../components/BookList.astro';
import books from '../../data/books.json';
---
<BaseLayout title="经验分享 - 无碍e家" showBreadcrumb breadcrumb={[{ label: '首页', href: '/' }, { label: '经验分享' }]}>
  <h1 class="text-2xl font-bold text-slate-800 mb-6">经验分享</h1>
  <p class="text-slate-600 mb-6">无障碍改造相关书籍推荐</p>
  <BookList books={books} />
</BaseLayout>
