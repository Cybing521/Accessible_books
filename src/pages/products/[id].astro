---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';

export function getStaticPaths() {
  return products.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const product = products.find((p) => p.id === id);
if (!product) return Astro.redirect('/products');

const PLACEHOLDER_IMG = "data:image/svg+xml," + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300"><rect width="400" height="300" fill="#f1f5f9"/><rect x="120" y="100" width="160" height="100" rx="4" fill="#e2e8f0"/><path d="M160 140l40 30 40-50 20 60" stroke="#94a3b8" stroke-width="2" fill="none"/><circle cx="180" cy="130" r="15" fill="#94a3b8"/><text x="200" y="230" text-anchor="middle" fill="#64748b" font-size="14" font-family="sans-serif">产品图片</text></svg>');
const imageSrc = product.image?.includes('placeholder') ? PLACEHOLDER_IMG : product.image;
---
<BaseLayout title={`${product.name} - 改造家居 - 无碍e家`}>
  <nav class="mb-6 text-sm text-slate-600" aria-label="面包屑">
    <a href="/" class="hover:text-blue-600">首页</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-blue-600">改造家居</a>
    <span class="mx-2">/</span>
    <span class="text-slate-800">{product.name}</span>
  </nav>

  <article class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <img src={imageSrc} alt={product.name} class="w-full max-w-2xl mx-auto h-64 object-cover bg-slate-100" />
    <div class="p-6">
      <h1 class="text-2xl font-bold text-slate-800 mb-4">{product.name}</h1>
      <dl class="space-y-2 text-slate-600">
        <div>
          <dt class="inline font-medium text-slate-500">产品分类：</dt>
          <dd class="inline">{product.category}</dd>
        </div>
        <div>
          <dt class="inline font-medium text-slate-500">适用场所：</dt>
          <dd class="inline">{product.venue || '通用'}</dd>
        </div>
        <div>
          <dt class="inline font-medium text-slate-500">适用人群：</dt>
          <dd class="inline">{product.audience || '—'}</dd>
        </div>
      </dl>
      <div class="mt-6 pt-6 border-t border-slate-200">
        <h2 class="font-semibold text-slate-800 mb-2">产品说明</h2>
        <p class="text-slate-600 whitespace-pre-line leading-relaxed">{product.material}</p>
      </div>
    </div>
  </article>

  <p class="mt-6">
    <a href="/products" class="text-blue-600 hover:text-blue-700 hover:underline">← 返回产品列表</a>
  </p>
</BaseLayout>
