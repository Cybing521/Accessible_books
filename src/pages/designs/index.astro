---
import BaseLayout from '../../layouts/BaseLayout.astro';
import designs from '../../data/designs.json';
---
<BaseLayout title="产品设计 - 无碍e家" showBreadcrumb breadcrumb={[{ label: '首页', href: '/' }, { label: '产品设计' }]}>
  <div class="mb-10 animate-spring-fade">
    <h1 class="text-2xl sm:text-3xl font-semibold text-morandi-text tracking-tight mb-2">产品设计</h1>
    <p class="text-morandi-muted">原创无障碍辅助产品设计方案</p>
  </div>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {designs.map((d, i) => (
      <a href={`/designs/${d.id}`} class="block glass spring-card rounded-2xl overflow-hidden animate-spring-in" style={`animation-delay: ${Math.min(i * 0.05, 0.3)}s`}>
        <img src={d.images[0]} alt={d.name} class="w-full h-48 object-contain p-2" loading="lazy" style="background: linear-gradient(135deg, #f5f0ec, #ede6e0, #f0ebe6);" />
        <div class="p-5">
          <h3 class="font-semibold text-morandi-text text-[15px]">{d.name}</h3>
          <p class="mt-2 text-sm text-morandi-subtle leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">{d.concept}</p>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
