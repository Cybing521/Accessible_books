---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="无碍e家 - 无障碍家居改造信息平台">
  <div class="mb-14 sm:mb-20 animate-spring-fade">
    <h1 class="text-3xl sm:text-4xl font-semibold text-morandi-text tracking-tight mb-3">无碍e家</h1>
    <p class="text-morandi-muted text-base sm:text-lg max-w-lg leading-relaxed">了解更多无障碍家居改造信息</p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 sm:gap-6">
    <a href="/products" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in stagger-1">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, var(--color-morandi-clay), var(--color-morandi-accent));">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">改造家居</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">肢体类、视障类、听障类产品</p>
    </a>
    <a href="/designs" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in stagger-2">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, #c4a6a0, #b8a99a);">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">产品设计</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">原创无障碍辅助产品设计</p>
    </a>
    <a href="/cases" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in stagger-3">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, #a3b5a6, #8aab8e);">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">整装案例设计</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">无障碍整装空间设计方案</p>
    </a>
    <a href="/policies" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in stagger-4">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, var(--color-morandi-sage), #8aab8e);">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">家居改造政策信息</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">政策文件与法规</p>
    </a>
    <a href="/books" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in stagger-5">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, var(--color-morandi-lavender), #9e94ac);">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">经验分享</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">无障碍改造相关书籍</p>
    </a>
    <a href="/mall" class="group glass spring-card rounded-2xl p-7 sm:p-8 block animate-spring-in" style="animation-delay: 0.3s;">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, var(--color-morandi-rose), var(--color-morandi-lavender));">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>
      </div>
      <h2 class="text-base font-semibold text-morandi-text mb-2">视障商城＆那伽树</h2>
      <p class="text-sm text-morandi-muted leading-relaxed">待开发</p>
    </a>
  </div>
</BaseLayout>
