---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="无碍e家 - 无障碍家居改造信息平台">
  <section class="hero-cover glass-strong animate-spring-in">
    <div class="hero-cover__media" aria-hidden="true">
      <img
        src="/images/home/cover-space-scene.jpg"
        alt=""
        class="hero-cover__bg"
        loading="eager"
        decoding="async"
      />
      <div class="hero-cover__veil"></div>
      <div class="hero-cover__glow"></div>
    </div>

    <div class="hero-cover__content">
      <div class="hero-cover__copy-panel glass animate-spring-fade">
        <p class="hero-cover__eyebrow">居家适老化与无障碍改造信息平台</p>
        <h1 class="hero-cover__title">无碍e家</h1>
        <p class="hero-cover__lede">
          把居家改造、辅助产品、整装案例、政策文件和经验资料放在同一个入口，
          让查资料、看方案、找方向这几件事更顺一些。
        </p>
        <div class="hero-cover__pill-row" aria-label="平台关键词">
          <span class="hero-cover__pill">适老化改造</span>
          <span class="hero-cover__pill">无障碍家居</span>
          <span class="hero-cover__pill">辅助产品</span>
          <span class="hero-cover__pill">空间案例</span>
        </div>
        <div class="hero-cover__actions">
          <a href="/products" class="hero-cover__button hero-cover__button--primary spring-btn">浏览改造家居</a>
          <a href="/policies" class="hero-cover__button hero-cover__button--secondary spring-btn">查看共享信息库</a>
        </div>
      </div>

      <div class="hero-cover__storyboard">
        <div class="hero-cover__focus animate-spring-in stagger-2">
          <div class="hero-cover__focus-card glass">
            <img
              src="/images/home/cover-heart-wordcloud.jpg"
              alt="以适老化改造、无障碍改造、养老与居家适配为关键词的心形词云"
              class="hero-cover__focus-image"
              loading="eager"
              decoding="async"
            />
          </div>
          <p class="hero-cover__focus-note">
            关键词聚焦：适老化、无障碍、居家改造、养老服务、社区支持。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="home-journey animate-spring-fade">
    <div class="home-journey__grid">
      <a href="/products" class="home-journey__card spring-card">
        <span class="home-journey__index">01</span>
        <h3 class="home-journey__card-title">先找合适产品</h3>
        <p class="home-journey__card-text">适合已经明确需求、想先了解辅助用品与改造器具的人。</p>
        <span class="home-journey__card-link">进入改造家居</span>
      </a>

      <a href="/cases" class="home-journey__card spring-card">
        <span class="home-journey__index">02</span>
        <h3 class="home-journey__card-title">先看空间案例</h3>
        <p class="home-journey__card-text">适合先看卧室、浴室、厨房等真实改造方向，再决定下一步的人。</p>
        <span class="home-journey__card-link">浏览整装案例</span>
      </a>

      <a href="/policies" class="home-journey__card spring-card">
        <span class="home-journey__index">03</span>
        <h3 class="home-journey__card-title">先确认政策依据</h3>
        <p class="home-journey__card-text">适合先了解补贴、法规和服务管理办法，再安排改造计划的人。</p>
        <span class="home-journey__card-link">查看共享信息库</span>
      </a>
    </div>
  </section>

  <section class="entry-deck">
    <div class="entry-deck__grid">
      <a href="/products" class="entry-card animate-spring-in stagger-1">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">产品目录</span>
            <span class="entry-card__meta">肢体 / 视障 / 听障</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, var(--color-morandi-clay), var(--color-morandi-accent));">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
          </div>
          <h3 class="entry-card__title">改造家居</h3>
          <p class="entry-card__text">按障碍类型整理辅助用品与家居改造产品，方便从具体需求快速切入。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">浏览产品入口</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <a href="/designs" class="entry-card animate-spring-in stagger-2">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">原创方案</span>
            <span class="entry-card__meta">辅助器具设计</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, #c4a6a0, #b8a99a);">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>
          </div>
          <h3 class="entry-card__title">产品设计</h3>
          <p class="entry-card__text">查看原创无障碍产品概念与设计思路，补充现有产品之外的方案想象。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">查看设计方案</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <a href="/cases" class="entry-card animate-spring-in stagger-3">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">空间参考</span>
            <span class="entry-card__meta">卧室 / 浴室 / 厨房</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, #a3b5a6, #8aab8e);">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/></svg>
          </div>
          <h3 class="entry-card__title">整装案例设计</h3>
          <p class="entry-card__text">从具体空间的动线、设施和细节改造出发，更容易理解整体方案怎么落地。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">浏览空间案例</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <a href="/policies" class="entry-card animate-spring-in stagger-4">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">共享信息库</span>
            <span class="entry-card__meta">政策 / 法规 / 动态</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, var(--color-morandi-sage), #8aab8e);">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
          </div>
          <h3 class="entry-card__title">共享信息库</h3>
          <p class="entry-card__text">集中查看政策文件、法规、行业动态和地方实施经验，为实际改造提供依据与参考。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">查看共享信息库</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <a href="/books" class="entry-card animate-spring-in stagger-5">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">经验资料</span>
            <span class="entry-card__meta">书籍与阅读</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, var(--color-morandi-lavender), #9e94ac);">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <h3 class="entry-card__title">经验分享</h3>
          <p class="entry-card__text">补充书籍与阅读材料，适合需要系统理解无障碍改造背景与经验的人。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">进入经验分享</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <a href="/mall" class="entry-card animate-spring-in" style="animation-delay: 0.3s;">
        <div class="entry-card__content">
          <div class="entry-card__topline">
            <span class="entry-card__badge">后续扩展</span>
            <span class="entry-card__meta">视障商城 / 那伽树</span>
          </div>
          <div class="entry-card__icon-shell" style="background: linear-gradient(135deg, var(--color-morandi-rose), var(--color-morandi-lavender));">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>
          </div>
          <h3 class="entry-card__title">视障商城＆那伽树</h3>
          <p class="entry-card__text">预留未来的服务与内容入口，让平台后续扩展仍然保持同一套视觉秩序。</p>
          <div class="entry-card__footer">
            <span class="entry-card__footer-text">查看预留入口</span>
            <span class="entry-card__arrow" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
