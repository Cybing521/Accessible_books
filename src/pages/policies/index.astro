---
import BaseLayout from '../../layouts/BaseLayout.astro';
import policies from '../../data/policies.json';
---
<BaseLayout title="家居改造政策信息 - 无碍e家">
  <h1 class="text-2xl font-bold text-slate-800 mb-6">家居改造政策信息</h1>
  <p class="text-slate-600 mb-6">政策文件与法规 PDF 下载</p>
  <ul class="space-y-3">
    {policies.map((p) => (
      <li>
        <a
          href={p.file}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 bg-white rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow transition"
        >
          <span class="font-medium text-slate-800">{p.title}</span>
          <span class="ml-2 text-blue-600 text-sm">→ 打开 PDF</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
