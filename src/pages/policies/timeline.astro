---
import BaseLayout from '../../layouts/BaseLayout.astro';
import policies from '../../data/policies.json';

const yearGroups: Record<number, typeof policies> = {};
for (const p of policies) {
  if (p.year) {
    if (!yearGroups[p.year]) yearGroups[p.year] = [];
    yearGroups[p.year].push(p);
  }
}
const sortedYears = Object.keys(yearGroups).map(Number).sort((a, b) => a - b);

const keywordPool: Record<string, string[]> = {
  "2018": ["居家改造","无障碍","服务管理","残疾人","北京市"],
  "2020": ["适老化","居家改造","残疾人","扶贫","脱贫","建档立卡","指导意见","无障碍"],
  "2021": ["十四五","无障碍环境","残疾人保障","发展规划","建设条例","实施方案"],
  "2022": ["困难重度","家庭改造","无障碍改造","青海","残疾人"],
  "2023": ["无障碍环境建设法","养老服务","基本养老","改造质量","全链条","残疾人"],
  "2024": ["适老化","无障碍出行","好房子","居家改造","产业发展","设计服务","温馨港湾"],
  "2025": ["家装焕新","民生实事","家庭改造","十四五规划","残疾人","适老化","好房子","多维度"],
  "2026": ["实施方案","超额完成","十四五收官","民生实事","片区改造","系统推进","无障碍设施"]
};

const yearKeywords = sortedYears.map(y => ({
  year: y,
  count: yearGroups[y].length,
  keywords: keywordPool[String(y)] || []
}));
---
<BaseLayout title="时间线与关键词可视化 - 共享信息库 - 无碍e家" showBreadcrumb breadcrumb={[{ label: '首页', href: '/' }, { label: '共享信息库', href: '/policies' }, { label: '时间线可视化' }]}>
  <div class="mb-10 animate-spring-fade">
    <h1 class="text-2xl sm:text-3xl font-semibold text-morandi-text tracking-tight mb-2">政策时间线与关键词可视化</h1>
    <p class="text-morandi-muted">按年份展示政策发布趋势与高频关键词</p>
  </div>

  <!-- 年度文件数量柱状图 -->
  <section class="glass rounded-2xl p-6 sm:p-8 mb-10 animate-spring-in">
    <h2 class="text-lg font-semibold text-morandi-text mb-6">年度发文趋势</h2>
    <div class="timeline-chart" id="timeline-chart" role="img" aria-label="年度发文数量柱状图"></div>
  </section>

  <!-- 时间线 -->
  <section class="timeline-section">
    <div class="timeline-track" aria-hidden="true"></div>
    {sortedYears.map((year, yi) => {
      const items = yearGroups[year];
      const kws = keywordPool[String(year)] || [];
      const isEven = yi % 2 === 0;
      return (
        <div class={`timeline-node animate-spring-in`} style={`animation-delay: ${Math.min(yi * 0.08, 0.5)}s`} data-year={year}>
          <div class="timeline-dot-wrap">
            <div class="timeline-dot"></div>
            <span class="timeline-year-label">{year}</span>
          </div>

          <div class="timeline-card glass spring-card rounded-2xl p-5">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xl font-bold text-morandi-text">{year}</span>
              <span class="px-2.5 py-0.5 rounded-lg text-xs glass-strong text-morandi-muted">{items.length} 篇</span>
            </div>

            {kws.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {kws.map((kw, ki) => (
                  <span
                    class="keyword-pill"
                    style={`animation-delay: ${Math.min(yi * 0.08 + ki * 0.04, 0.8)}s; --kw-size: ${Math.max(0.82, 1.02 - ki * 0.03)}rem`}
                  >
                    {kw}
                  </span>
                ))}
              </div>
            )}

            <ul class="space-y-2">
              {items.map(p => (
                <li>
                  <a href={p.file} target="_blank" rel="noopener noreferrer"
                    class="flex items-center gap-3 py-2 px-3 rounded-xl text-sm text-morandi-muted hover:text-morandi-text hover:bg-white/30 transition-all duration-300">
                    <svg class="w-3.5 h-3.5 flex-shrink-0 text-morandi-subtle" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                    <span class="flex-1 min-w-0" style="display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">{p.title}</span>
                    <svg class="w-3 h-3 flex-shrink-0 text-morandi-subtle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      );
    })}
  </section>

  <div class="mt-10 mb-4">
    <a href="/policies" class="inline-flex items-center gap-2 text-sm text-morandi-muted hover:text-morandi-text spring-btn transition-colors duration-300">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
      返回共享信息库
    </a>
  </div>
</BaseLayout>

<style>
  .timeline-chart {
    display: flex;
    align-items: flex-end;
    gap: clamp(0.5rem, 2vw, 1.2rem);
    height: 180px;
    padding: 0 0.5rem;
  }

  .chart-bar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    height: 100%;
    justify-content: flex-end;
  }

  .chart-bar {
    width: 100%;
    max-width: 3.5rem;
    border-radius: 0.6rem 0.6rem 0.2rem 0.2rem;
    background: linear-gradient(180deg, var(--color-morandi-sage), #8aab8e);
    position: relative;
    min-height: 4px;
    transform-origin: bottom center;
    animation: bar-grow 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .chart-bar-count {
    position: absolute;
    top: -1.6rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-morandi-text);
  }

  .chart-bar-year {
    font-size: 0.75rem;
    color: var(--color-morandi-muted);
    font-weight: 600;
  }

  @keyframes bar-grow {
    0% { transform: scaleY(0); opacity: 0; }
    100% { transform: scaleY(1); opacity: 1; }
  }

  .timeline-section {
    position: relative;
    padding: 2rem 0;
  }

  .timeline-track {
    position: absolute;
    left: 1.25rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg,
      transparent 0%,
      var(--color-morandi-border) 4%,
      var(--color-morandi-sage) 50%,
      var(--color-morandi-border) 96%,
      transparent 100%
    );
    border-radius: 1px;
  }

  .timeline-node {
    position: relative;
    padding-left: 3.5rem;
    margin-bottom: 2rem;
  }

  .timeline-dot-wrap {
    position: absolute;
    left: 0;
    top: 0.3rem;
    width: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .timeline-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-morandi-sage), #8aab8e);
    box-shadow: 0 0 0 3px var(--color-morandi-bg), 0 0 0 5px var(--color-morandi-sage);
    flex-shrink: 0;
  }

  .timeline-year-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-morandi-muted);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .keyword-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    font-size: var(--kw-size, 0.85rem);
    font-weight: 500;
    color: #5a7560;
    background: rgba(163, 181, 166, 0.18);
    border: 1px solid rgba(163, 181, 166, 0.25);
    animation: spring-fade-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease;
  }

  .keyword-pill:hover {
    transform: translateY(-2px) scale(1.04);
    background: rgba(163, 181, 166, 0.3);
  }

  @media (min-width: 640px) {
    .timeline-track {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline-node {
      padding-left: 0;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .timeline-node:nth-child(odd) .timeline-card {
      grid-column: 1;
      grid-row: 1;
    }
    .timeline-node:nth-child(odd) .timeline-dot-wrap {
      position: static;
      grid-column: 2;
      grid-row: 1;
      width: auto;
      padding-top: 0.2rem;
    }

    .timeline-node:nth-child(even) .timeline-card {
      grid-column: 3;
      grid-row: 1;
    }
    .timeline-node:nth-child(even) .timeline-dot-wrap {
      position: static;
      grid-column: 2;
      grid-row: 1;
      width: auto;
      padding-top: 0.2rem;
    }
  }

  :global(html.dark) .timeline-dot {
    box-shadow: 0 0 0 3px #1e1c1a, 0 0 0 5px var(--color-morandi-sage);
  }

  :global(html.dark) .keyword-pill {
    color: #a3c4a8;
    background: rgba(163, 181, 166, 0.12);
    border-color: rgba(163, 181, 166, 0.18);
  }

  :global(html.dark) .keyword-pill:hover {
    background: rgba(163, 181, 166, 0.22);
  }

  :global(html.dark) .chart-bar {
    background: linear-gradient(180deg, var(--color-morandi-sage), #6a8a6e);
  }

  @media (prefers-reduced-motion: reduce) {
    .chart-bar { animation: none; }
    .keyword-pill { animation: none; }
  }
</style>

<script define:vars={{ yearKeywords }}>
  const chartEl = document.getElementById('timeline-chart');
  if (chartEl && yearKeywords.length > 0) {
    const maxCount = Math.max(...yearKeywords.map(y => y.count));
    chartEl.innerHTML = yearKeywords.map((y, i) => {
      const heightPct = Math.max(8, (y.count / maxCount) * 100);
      const delay = i * 0.1;
      return `
        <div class="chart-bar-group">
          <div class="chart-bar" style="height: ${heightPct}%; animation-delay: ${delay}s;">
            <span class="chart-bar-count">${y.count}</span>
          </div>
          <span class="chart-bar-year">${y.year}</span>
        </div>
      `;
    }).join('');
  }
</script>
