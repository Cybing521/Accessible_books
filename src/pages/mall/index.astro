---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="视障商城＆那伽树 - 无碍e家" showBreadcrumb breadcrumb={[{ label: '首页', href: '/' }, { label: '视障商城＆那伽树' }]}>
  <div class="animate-spring-fade">
    <h1 class="text-2xl sm:text-3xl font-semibold text-morandi-text tracking-tight mb-2">视障商城＆那伽树</h1>
    <p class="text-morandi-muted mb-16">视障人群专属购物与服务平台</p>
  </div>

  <div class="flex flex-col items-center justify-center py-16 animate-spring-in">
    <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-8" style="background: linear-gradient(135deg, var(--color-morandi-rose), var(--color-morandi-lavender));">
      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"/></svg>
    </div>
    <h2 class="text-xl font-semibold text-morandi-text mb-3">功能开发中</h2>
    <p class="text-morandi-muted text-center max-w-md leading-relaxed">该模块正在紧锣密鼓地开发中，敬请期待。我们将为视障人群打造专属的购物与服务体验。</p>
  </div>
</BaseLayout>
