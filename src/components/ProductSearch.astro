---
interface Props {
  products: Array<{
    id: string;
    name: string;
    category: string;
    venue: string;
    audience: string;
    material: string;
    image: string;
  }>;
}
const { products } = Astro.props;
---
<div class="mb-6">
  <input
    type="search"
    id="product-search"
    placeholder="搜索产品名称、适用场所、适用人群..."
    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    aria-label="搜索产品"
  />
</div>
<div id="product-list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>
<nav id="pagination" class="mt-8 flex justify-center gap-2 flex-wrap" aria-label="分页"></nav>

<script define:vars={{ products }}>
  const PER_PAGE = 12;
  const searchEl = document.getElementById('product-search');
  const listEl = document.getElementById('product-list');
  const paginationEl = document.getElementById('pagination');

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }
  function renderCard(p) {
    const venue = escapeHtml(p.venue || '—');
    const audience = escapeHtml(p.audience || '—');
    const material = escapeHtml((p.material || '').slice(0, 80) + ((p.material || '').length > 80 ? '…' : ''));
    const name = escapeHtml(p.name);
    const image = escapeHtml(p.image);
    return `
      <article class="bg-white rounded-lg border border-slate-200 overflow-hidden">
        <img src="${image}" alt="${name}" class="w-full h-40 object-cover bg-slate-100" />
        <div class="p-4">
          <h3 class="font-semibold text-slate-800">${name}</h3>
          <p class="mt-1 text-sm text-slate-600"><span class="text-slate-500">适用场所：</span>${venue}</p>
          <p class="mt-1 text-sm text-slate-600"><span class="text-slate-500">适用人群：</span>${audience}</p>
          <p class="mt-2 text-sm text-slate-600" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${material}</p>
        </div>
      </article>
    `;
  }

  function filterProducts(query) {
    const q = (query || '').trim().toLowerCase();
    if (!q) return products;
    return products.filter(
      (p) =>
        (p.name && p.name.toLowerCase().includes(q)) ||
        (p.venue && p.venue.toLowerCase().includes(q)) ||
        (p.audience && p.audience.toLowerCase().includes(q)) ||
        (p.category && p.category.toLowerCase().includes(q)) ||
        (p.material && p.material.toLowerCase().includes(q))
    );
  }

  function renderPage(filtered, page) {
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    const p = Math.min(Math.max(1, page), totalPages);
    const start = (p - 1) * PER_PAGE;
    const pageItems = filtered.slice(start, start + PER_PAGE);

    listEl.innerHTML = pageItems.map(renderCard).join('');

    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const prevBtn = document.createElement('button');
    prevBtn.className = 'px-3 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed';
    prevBtn.textContent = '上一页';
    prevBtn.disabled = p <= 1;
    prevBtn.addEventListener('click', () => { renderPage(filtered, p - 1); });
    paginationEl.appendChild(prevBtn);

    const span = document.createElement('span');
    span.className = 'px-3 py-1 text-slate-600';
    span.textContent = `第 ${p} / ${totalPages} 页`;
    paginationEl.appendChild(span);

    const nextBtn = document.createElement('button');
    nextBtn.className = 'px-3 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed';
    nextBtn.textContent = '下一页';
    nextBtn.disabled = p >= totalPages;
    nextBtn.addEventListener('click', () => { renderPage(filtered, p + 1); });
    paginationEl.appendChild(nextBtn);
  }

  function update() {
    const query = searchEl.value;
    const filtered = filterProducts(query);
    renderPage(filtered, 1);
  }

  searchEl.addEventListener('input', update);
  searchEl.addEventListener('search', update);
  update();
</script>
