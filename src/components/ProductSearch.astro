---
interface Props {
  products: Array<{
    id: string;
    name: string;
    category: string;
    venue: string;
    audience: string;
    material: string;
    image: string;
  }>;
}
const { products } = Astro.props;
---
<div class="mb-6 space-y-4">
  <input
    type="search"
    id="product-search"
    placeholder="搜索产品名称、适用场所、适用人群..."
    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    aria-label="搜索产品"
  />
  <div class="flex flex-wrap gap-2" role="group" aria-label="筛选">
    <span class="text-sm text-slate-600 py-1">分类：</span>
    <button type="button" data-filter-cat="" class="filter-cat px-3 py-1 rounded-full text-sm border border-slate-300 bg-blue-50 text-blue-700 border-blue-300">全部</button>
    <button type="button" data-filter-cat="肢体类" class="filter-cat px-3 py-1 rounded-full text-sm border border-slate-300 text-slate-600 hover:bg-slate-50">肢体类</button>
    <button type="button" data-filter-cat="视障类" class="filter-cat px-3 py-1 rounded-full text-sm border border-slate-300 text-slate-600 hover:bg-slate-50">视障类</button>
    <button type="button" data-filter-cat="听障类" class="filter-cat px-3 py-1 rounded-full text-sm border border-slate-300 text-slate-600 hover:bg-slate-50">听障类</button>
    <span class="text-sm text-slate-600 py-1 ml-4">场所：</span>
    <select id="product-venue" class="px-3 py-1 rounded-lg border border-slate-300 text-sm text-slate-700 focus:ring-2 focus:ring-blue-500" aria-label="按适用场所筛选">
      <option value="">全部</option>
    </select>
  </div>
</div>
<div id="product-list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>
<div id="product-empty" class="hidden text-center py-16 text-slate-500">
  <p class="text-lg">暂无匹配的产品</p>
  <p class="mt-2 text-sm">尝试调整搜索关键词或筛选条件</p>
</div>
<nav id="pagination" class="mt-8 flex justify-center gap-2 flex-wrap" aria-label="分页"></nav>

<script define:vars={{ products }}>
  const PER_PAGE = 12;
  const PLACEHOLDER_IMG = "data:image/svg+xml," + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300"><rect width="400" height="300" fill="#f1f5f9"/><rect x="120" y="100" width="160" height="100" rx="4" fill="#e2e8f0"/><path d="M160 140l40 30 40-50 20 60" stroke="#94a3b8" stroke-width="2" fill="none"/><circle cx="180" cy="130" r="15" fill="#94a3b8"/><text x="200" y="230" text-anchor="middle" fill="#64748b" font-size="14" font-family="sans-serif">产品图片</text></svg>');
  const searchEl = document.getElementById('product-search');
  const listEl = document.getElementById('product-list');
  const paginationEl = document.getElementById('pagination');

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }
  function getImageSrc(src) {
    if (!src || src.includes('placeholder')) return PLACEHOLDER_IMG;
    return src.startsWith('data:') ? src : (src.startsWith('/') ? window.location.origin + src : src);
  }
  function renderCard(p) {
    const venue = escapeHtml(p.venue || '—');
    const audience = escapeHtml(p.audience || '—');
    const material = escapeHtml((p.material || '').slice(0, 80) + ((p.material || '').length > 80 ? '…' : ''));
    const name = escapeHtml(p.name);
    const imageSrc = getImageSrc(p.image);
    const id = escapeHtml(p.id);
    return `
      <a href="/products/${id}" class="block bg-white rounded-lg border border-slate-200 overflow-hidden hover:border-blue-300 hover:shadow-md transition">
        <img src="${imageSrc}" alt="${name}" class="w-full h-40 object-cover bg-slate-100" loading="lazy" />
        <div class="p-4">
          <h3 class="font-semibold text-slate-800">${name}</h3>
          <p class="mt-1 text-sm text-slate-600"><span class="text-slate-500">适用场所：</span>${venue}</p>
          <p class="mt-1 text-sm text-slate-600"><span class="text-slate-500">适用人群：</span>${audience}</p>
          <p class="mt-2 text-sm text-slate-600" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${material}</p>
        </div>
      </a>
    `;
  }

  const venueSelect = document.getElementById('product-venue');
  const emptyEl = document.getElementById('product-empty');
  const venues = [...new Set(products.map(p => p.venue).filter(Boolean))].sort();
  venues.forEach(v => {
    const opt = document.createElement('option');
    opt.value = v;
    opt.textContent = v;
    venueSelect.appendChild(opt);
  });

  document.querySelectorAll('.filter-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-cat').forEach(b => {
        b.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-300');
        b.classList.add('text-slate-600');
      });
      btn.classList.add('bg-blue-50', 'text-blue-700', 'border-blue-300');
      btn.classList.remove('text-slate-600');
      update();
    });
  });
  venueSelect.addEventListener('change', update);

  function filterProducts(query, category, venue) {
    let result = products;
    if (category) result = result.filter(p => p.category === category);
    if (venue) result = result.filter(p => p.venue === venue);
    const q = (query || '').trim().toLowerCase();
    if (q) {
      result = result.filter(
        (p) =>
          (p.name && p.name.toLowerCase().includes(q)) ||
          (p.venue && p.venue.toLowerCase().includes(q)) ||
          (p.audience && p.audience.toLowerCase().includes(q)) ||
          (p.category && p.category.toLowerCase().includes(q)) ||
          (p.material && p.material.toLowerCase().includes(q))
      );
    }
    return result;
  }

  function renderPage(filtered, page) {
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    const p = Math.min(Math.max(1, page), totalPages);
    const start = (p - 1) * PER_PAGE;
    const pageItems = filtered.slice(start, start + PER_PAGE);

    if (total === 0) {
      listEl.innerHTML = '';
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      paginationEl.innerHTML = '';
      return;
    }
    listEl.classList.remove('hidden');
    emptyEl.classList.add('hidden');
    listEl.innerHTML = pageItems.map(renderCard).join('');

    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const prevBtn = document.createElement('button');
    prevBtn.className = 'px-3 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed';
    prevBtn.textContent = '上一页';
    prevBtn.disabled = p <= 1;
    prevBtn.addEventListener('click', () => { renderPage(filtered, p - 1); });
    paginationEl.appendChild(prevBtn);

    const span = document.createElement('span');
    span.className = 'px-3 py-1 text-slate-600';
    span.textContent = `第 ${p} / ${totalPages} 页`;
    paginationEl.appendChild(span);

    const nextBtn = document.createElement('button');
    nextBtn.className = 'px-3 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed';
    nextBtn.textContent = '下一页';
    nextBtn.disabled = p >= totalPages;
    nextBtn.addEventListener('click', () => { renderPage(filtered, p + 1); });
    paginationEl.appendChild(nextBtn);
  }

  function update() {
    const query = searchEl.value;
    const activeCat = document.querySelector('.filter-cat.bg-blue-50')?.dataset.filterCat || '';
    const venue = venueSelect.value || '';
    const filtered = filterProducts(query, activeCat, venue);
    renderPage(filtered, 1);
  }

  searchEl.addEventListener('input', update);
  searchEl.addEventListener('search', update);
  update();
</script>
