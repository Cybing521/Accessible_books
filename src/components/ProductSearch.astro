---
interface Props {
  products: Array<{
    id: string;
    name: string;
    category: string;
    venue: string;
    audience: string;
    material: string;
    image: string;
  }>;
}
const { products } = Astro.props;
---
<div class="mb-8 space-y-5 animate-spring-fade">
  <input
    type="search"
    id="product-search"
    placeholder="搜索产品名称、适用场所、适用人群..."
    class="w-full px-5 py-3 glass rounded-xl text-morandi-text placeholder-morandi-subtle focus:outline-none focus:ring-2 focus:ring-morandi-accent/30 transition-all duration-300"
    aria-label="搜索产品"
  />
  <div class="flex flex-wrap items-center gap-2.5" role="group" aria-label="筛选">
    <span class="text-xs uppercase tracking-widest text-morandi-subtle mr-1">分类</span>
    <button type="button" data-filter-cat="" class="filter-cat px-4 py-2 rounded-xl text-sm spring-btn glass-strong text-morandi-text font-medium active-filter">全部</button>
    <button type="button" data-filter-cat="肢体类" class="filter-cat px-4 py-2 rounded-xl text-sm spring-btn glass text-morandi-muted">肢体类</button>
    <button type="button" data-filter-cat="视障类" class="filter-cat px-4 py-2 rounded-xl text-sm spring-btn glass text-morandi-muted">视障类</button>
    <button type="button" data-filter-cat="听障类" class="filter-cat px-4 py-2 rounded-xl text-sm spring-btn glass text-morandi-muted">听障类</button>
    <span class="text-xs uppercase tracking-widest text-morandi-subtle ml-3 mr-1">场所</span>
    <select id="product-venue" class="px-4 py-2 rounded-xl text-sm glass text-morandi-muted focus:outline-none focus:ring-2 focus:ring-morandi-accent/30" aria-label="按适用场所筛选">
      <option value="">全部</option>
    </select>
  </div>
</div>
<div id="product-list" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 sm:gap-6"></div>
<div id="product-empty" class="hidden text-center py-20 text-morandi-muted">
  <p class="text-morandi-text">暂无匹配的产品</p>
  <p class="mt-2 text-sm text-morandi-subtle">尝试调整搜索关键词或筛选条件</p>
</div>
<nav id="pagination" class="mt-10 flex justify-center gap-2.5 flex-wrap" aria-label="分页"></nav>

<script define:vars={{ products }}>
  const PER_PAGE = 12;
  const PLACEHOLDER_IMG = "data:image/svg+xml," + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300"><defs><linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#e8e0da"/><stop offset="50%" style="stop-color:#d6ccc4"/><stop offset="100%" style="stop-color:#e2dbd5"/></linearGradient></defs><rect width="400" height="300" fill="url(#g)"/><circle cx="200" cy="130" r="28" fill="none" stroke="#b4a79e" stroke-width="1.5" opacity="0.5"/><path d="M188 130l8 8 16-16" stroke="#b4a79e" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/><text x="200" y="185" text-anchor="middle" fill="#b4a79e" font-size="12" font-family="system-ui" opacity="0.6">暂无图片</text></svg>');
  const searchEl = document.getElementById('product-search');
  const listEl = document.getElementById('product-list');
  const paginationEl = document.getElementById('pagination');

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }
  function getImageSrc(src) {
    if (!src || src.includes('placeholder')) return PLACEHOLDER_IMG;
    return src.startsWith('data:') ? src : (src.startsWith('/') ? window.location.origin + src : src);
  }
  function renderCard(p, i) {
    const venue = escapeHtml(p.venue || '—');
    const audience = escapeHtml(p.audience || '—');
    const material = escapeHtml((p.material || '').slice(0, 80) + ((p.material || '').length > 80 ? '…' : ''));
    const name = escapeHtml(p.name);
    const imageSrc = getImageSrc(p.image);
    const id = escapeHtml(p.id);
    const delay = Math.min(i * 0.04, 0.3);
    return `
      <a href="/products/${id}" class="block glass spring-card rounded-2xl overflow-hidden" style="animation: spring-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) ${delay}s both;">
        <img src="${imageSrc}" alt="${name}" class="w-full h-44 object-cover" loading="lazy" style="background: linear-gradient(135deg, #e8e0da, #d6ccc4, #e2dbd5);" />
        <div class="p-5">
          <h3 class="font-semibold text-morandi-text text-[15px]">${name}</h3>
          <p class="mt-2 text-sm text-morandi-muted"><span class="text-morandi-subtle">适用场所：</span>${venue}</p>
          <p class="mt-1 text-sm text-morandi-muted"><span class="text-morandi-subtle">适用人群：</span>${audience}</p>
          <p class="mt-2.5 text-sm text-morandi-subtle leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${material}</p>
        </div>
      </a>
    `;
  }

  const venueSelect = document.getElementById('product-venue');
  const emptyEl = document.getElementById('product-empty');
  const venues = [...new Set(products.map(p => p.venue).filter(Boolean))].sort();
  venues.forEach(v => {
    const opt = document.createElement('option');
    opt.value = v;
    opt.textContent = v;
    venueSelect.appendChild(opt);
  });

  document.querySelectorAll('.filter-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-cat').forEach(b => {
        b.classList.remove('glass-strong', 'text-morandi-text', 'font-medium', 'active-filter');
        b.classList.add('glass', 'text-morandi-muted');
      });
      btn.classList.add('glass-strong', 'text-morandi-text', 'font-medium', 'active-filter');
      btn.classList.remove('glass', 'text-morandi-muted');
      update();
    });
  });
  venueSelect.addEventListener('change', update);

  function filterProducts(query, category, venue) {
    let result = products;
    if (category) result = result.filter(p => p.category === category);
    if (venue) result = result.filter(p => p.venue === venue);
    const q = (query || '').trim().toLowerCase();
    if (q) {
      result = result.filter(
        (p) =>
          (p.name && p.name.toLowerCase().includes(q)) ||
          (p.venue && p.venue.toLowerCase().includes(q)) ||
          (p.audience && p.audience.toLowerCase().includes(q)) ||
          (p.category && p.category.toLowerCase().includes(q)) ||
          (p.material && p.material.toLowerCase().includes(q))
      );
    }
    return result;
  }

  function renderPage(filtered, page) {
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    const p = Math.min(Math.max(1, page), totalPages);
    const start = (p - 1) * PER_PAGE;
    const pageItems = filtered.slice(start, start + PER_PAGE);

    if (total === 0) {
      listEl.innerHTML = '';
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      paginationEl.innerHTML = '';
      return;
    }
    listEl.classList.remove('hidden');
    emptyEl.classList.add('hidden');
    listEl.innerHTML = pageItems.map((item, i) => renderCard(item, i)).join('');

    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const prevBtn = document.createElement('button');
    prevBtn.className = 'px-4 py-2 rounded-xl glass spring-btn text-sm text-morandi-muted disabled:opacity-40 disabled:cursor-not-allowed';
    prevBtn.textContent = '上一页';
    prevBtn.disabled = p <= 1;
    prevBtn.addEventListener('click', () => { renderPage(filtered, p - 1); });
    paginationEl.appendChild(prevBtn);

    const span = document.createElement('span');
    span.className = 'px-4 py-2 text-morandi-subtle text-sm';
    span.textContent = `${p} / ${totalPages}`;
    paginationEl.appendChild(span);

    const nextBtn = document.createElement('button');
    nextBtn.className = 'px-4 py-2 rounded-xl glass spring-btn text-sm text-morandi-muted disabled:opacity-40 disabled:cursor-not-allowed';
    nextBtn.textContent = '下一页';
    nextBtn.disabled = p >= totalPages;
    nextBtn.addEventListener('click', () => { renderPage(filtered, p + 1); });
    paginationEl.appendChild(nextBtn);
  }

  function update() {
    const query = searchEl.value;
    const activeCat = document.querySelector('.filter-cat.active-filter')?.dataset.filterCat || '';
    const venue = venueSelect.value || '';
    const filtered = filterProducts(query, activeCat, venue);
    renderPage(filtered, 1);
  }

  searchEl.addEventListener('input', update);
  searchEl.addEventListener('search', update);
  update();
</script>
