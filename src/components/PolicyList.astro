---
interface Props {
  policies: Array<{ id: string; title: string; file: string }>;
}
const { policies } = Astro.props;
---
<div class="mb-6">
  <input
    type="search"
    id="policy-search"
    placeholder="搜索政策标题..."
    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    aria-label="搜索政策"
  />
</div>
<ul id="policy-list" class="space-y-3"></ul>
<div id="policy-empty" class="hidden text-center py-16 text-slate-500">
  <p class="text-lg">暂无匹配的政策文件</p>
  <p class="mt-2 text-sm">尝试调整搜索关键词</p>
</div>

<script define:vars={{ policies }}>
  const searchEl = document.getElementById('policy-search');
  const listEl = document.getElementById('policy-list');
  const emptyEl = document.getElementById('policy-empty');

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function renderItem(p) {
    const title = escapeHtml(p.title);
    const file = escapeHtml(p.file);
    return `
      <li>
        <a href="${file}" target="_blank" rel="noopener noreferrer"
          class="block p-4 bg-white rounded-lg border border-slate-200 hover:border-blue-300 hover:shadow transition">
          <span class="font-medium text-slate-800">${title}</span>
          <span class="ml-2 text-blue-600 text-sm">→ 打开 PDF</span>
        </a>
      </li>
    `;
  }

  function update() {
    const q = (searchEl.value || '').trim().toLowerCase();
    const filtered = q
      ? policies.filter((p) => p.title && p.title.toLowerCase().includes(q))
      : policies;

    if (filtered.length === 0) {
      listEl.innerHTML = '';
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
    } else {
      listEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      listEl.innerHTML = filtered.map(renderItem).join('');
    }
  }

  searchEl.addEventListener('input', update);
  searchEl.addEventListener('search', update);
  update();
</script>
